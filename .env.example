# =============================================================================
# Arc DevKit — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no git.
# =============================================================================
# Token do PyPI — necessário apenas para publicar o pacote no PyPI (CI/CD)
# Gere em: https://pypi.org/manage/account/token/
TOKEN_PYPI=pypi-...

# Chave da API Anthropic — obrigatória para o Dev Copilot e Tx Debugger
# Obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# URL do nó RPC da Arc
# Testnet (desenvolvimento): https://rpc.arc.io/testnet
# Mainnet (produção, verão 2026): configurar quando disponível
ARC_RPC_URL=https://rpc.arc.io/testnet

# Chain ID da rede Arc
# Testnet: 7777777 (verifique na documentação oficial da Arc)
ARC_CHAIN_ID=7777777

# Chave privada da carteira — opcional
# Necessária apenas para operações que enviam transações (agentes, pagamentos)
# Formato: hex sem prefixo 0x
# ATENÇÃO: nunca use sua carteira principal aqui — crie uma carteira dedicada para testes
ARC_PRIVATE_KEY=

# Nível de log da aplicação
# Opções: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
